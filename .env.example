# Flask Configuration
FLASK_ENV=development
FLASK_APP=backend/run.py
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/datacure_db

# Firebase Configuration
FIREBASE_CREDENTIALS_PATH=./backend/config/firebase-credentials.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=2592000

# AWS Configuration (Optional)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=datacure-hospital-files

# File Upload Configuration
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=./backend/uploads
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,dcm,xls,xlsx

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO
LOG_FILE=./backend/logs/app.log

# AI/ML Configuration
MODEL_CACHE_DIR=./backend/ai/models
TRAINING_DATA_PATH=./backend/ai/data

# Deployment
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
